# =========================
# Quantum Minesweeper .env
# =========================

# --- Authentication (Basic Auth) ---
QMS_ENABLE_AUTH=0
QMS_USER=change-me
QMS_PASS=change-me
# Admin dashboard password. Leave unset to disable the /admin routes entirely.
# NOTE: no spaces around '=' (the value is taken verbatim, including spaces).
QMS_ADMIN_PASS=change-me

# --- Runtime (app) ---
QMS_BACKEND=stim
# Optional: set if the app is mounted behind a reverse proxy path or custom domain
# QMS_BASE_URL=https://your-app.a.run.app

# --- Feature flags ---
QMS_ENABLE_HELP=1
QMS_ENABLE_TUTORIAL=0
QMS_TUTORIAL_URL=docs/tutorial
QMS_ENABLE_SURVEY=1
QMS_SURVEY_URL=survey.com

# --- Local/Deploy convenience (non-app) ---
# Used by local scripts / Docker entrypoint; Cloud Run injects PORT automatically.
PORT=8080
